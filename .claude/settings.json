{
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch --show-current)",
      "Bash(git branch -a)",
      "Bash(git branch -v)",
      "Bash(git remote -v)",
      "Bash(git stash list*)",
      "Bash(ls*)",
      "Bash(pgrep *)",
      "Bash(npm run typecheck*)",
      "Bash(npm run test*)",
      "Bash(npm run check*)",
      "Bash(npm run build*)",
      "Bash(npm run audit:moderate*)",
      "Bash(npm run dev*)",
      "Bash(npm --prefix backend run typecheck*)",
      "Bash(npm --prefix backend run test*)",
      "Bash(npm --prefix backend run build*)",
      "Bash(npm --prefix backend run dev*)",
      "Bash(npm --prefix backend audit*)",
      "Bash(npm --prefix frontend run typecheck*)",
      "Bash(npm --prefix frontend run build*)",
      "Bash(npm --prefix frontend run dev*)",
      "Bash(npm --prefix frontend audit*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git push origin --delete*)",
      "Bash(git push * --delete*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git clean -d*)",
      "Bash(git branch -D*)",
      "Bash(git filter-branch*)",
      "Bash(rm -rf*)",
      "Bash(rm -fr*)",
      "Bash(sudo rm -rf*)",
      "Bash(sudo rm -fr*)",
      "Bash(docker system prune*)",
      "Bash(docker volume prune*)",
      "Bash(docker volume rm*)",
      "Bash(docker compose down -v*)",
      "Bash(docker compose* down -v*)",
      "Bash(npm publish*)"
    ]
  }
}
