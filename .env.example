HOST_FILES_DIR=/home/pi
FRONTEND_PORT=8080
DATA_DIR=./data
# Native dev: paths above/below are relative to the repo root when running npm run dev:backend
DATABASE_PATH=./data/integritas-pi.db
MINIMA_STATUS_URL=http://127.0.0.1:9005/status
PORT=3000
APP_SECRET=dev-change-me
# Set COOKIE_SECURE=true for Docker HTTPS deploy; false for native npm run dev (HTTP :5173)
COOKIE_SECURE=false
SESSION_MAX_AGE_DAYS=7
SESSION_IDLE_HOURS=24
DOCKER_GID=0
# Set ENABLE_GPIO=true to have install.sh create a Docker Compose override that mounts /dev/gpiochip0 for GPIO input sources.
ENABLE_GPIO=false
GPIO_GID=0
MINIMA_DATA_DIR=./minima
MINIMA_P2P_PORT=9003
MINIMA_RPC_BIND=127.0.0.1
MINIMA_RPC_PORT=9005
MINIMA_HEALTH_POLL_INTERVAL_SECONDS=60
MINIMA_STALL_BLOCK_AGE_SECONDS=300
MINIMA_AUTO_RESYNC=false
MINIMA_AUTO_RESYNC_COOLDOWN_MINUTES=30
INTEGRITAS_BASE_URL=https://integritas.technology/core
INTEGRITAS_API_KEY=
INTEGRITAS_REQUEST_ID=integritas-pi
INTEGRITAS_REQUEST_TIMEOUT_MS=15000
INTEGRITAS_POLL_INTERVAL_SECONDS=30
INTEGRITAS_PROOF_POLL_TIMEOUT_MINUTES=5
# External portal link shown in Integritas config modal (defaults to profile API logs tab)
INTEGRITAS_PORTAL_URL=
# URL of the signed update manifest hosted on the VPS (e.g. https://updates.example.com/manifest.json)
# install.sh also reads this to fetch the exact frontend/backend image digests for a fresh install.
MANIFEST_URL=
# Frontend/backend image refs (ghcr.io digest), resolved by install.sh from the manifest at install time.
# Not meant to be set by hand.
FRONTEND_IMAGE=
BACKEND_IMAGE=
RELEASE_CHANNEL=stable
UPDATE_HEALTH_CHECK_TIMEOUT_MS=60000
UPDATE_HEALTH_CHECK_INTERVAL_MS=2000
# How long update-agent waits for a Docker image pull to finish before giving up; raise on slow connections
UPDATE_PULL_TIMEOUT_MS=300000
# How often update-agent checks the manifest in the background (ms). Default is once a day; lower this for QA/testing (e.g. 300000 = 5 min).
STATUS_POLL_INTERVAL_MS=86400000
# Host path update-agent persists its own state to (currently: the last successfully applied manifest's createdAt, to reject replayed/downgraded manifests)
UPDATE_AGENT_STATE_DIR=./update-agent-state
